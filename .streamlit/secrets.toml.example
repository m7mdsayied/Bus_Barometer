# .streamlit/secrets.toml — Cloud deployment user store
# Copy this file to secrets.toml and replace the placeholder hashes.
# Generate a bcrypt hash with: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
#
# This file is tracked in git (example only — no real passwords).
# The real secrets.toml is in .gitignore.

[users.admin]
password = "$2b$12$REPLACE_WITH_BCRYPT_HASH_FOR_ADMIN"
role     = "admin"
enabled  = true

[users.editor]
password = "$2b$12$REPLACE_WITH_BCRYPT_HASH_FOR_EDITOR"
role     = "editor"
enabled  = true

[users.viewer]
password = "$2b$12$REPLACE_WITH_BCRYPT_HASH_FOR_VIEWER"
role     = "viewer"
enabled  = true
